SECRET_KEY=troque-esta-chave
DEBUG=False
ALLOWED_HOSTS=beezap.seudominio.com,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://beezap.seudominio.com

# Prefixo de caminho quando o app roda sob um sub-caminho (ex.: dominio.com/beezap/).
# Faz o Django gerar todas as URLs (links, redirects) com o prefixo. Deixe vazio
# se o app roda na raiz de um dominio proprio.
FORCE_SCRIPT_NAME=/beezap

# URL publica dos arquivos estaticos e de midia.
# - Padrao (dominio proprio): /static/  e  /media/
# - Se o app roda sob um prefixo de caminho (ex.: dominio.com/beezap/): /beezap/static/ e /beezap/media/
STATIC_URL=/beezap/static/
MEDIA_URL=/beezap/media/

# SQLite temporario para homologacao simples:
DATABASE_URL=sqlite:////var/www/beezap/db.sqlite3

# PostgreSQL recomendado para evolucao:
# DATABASE_URL=postgresql://beezap_user:troque-a-senha@127.0.0.1:5432/beezap_db

WAPI_BASE_URL=https://api.w-api.app
WAPI_INSTANCE_ID=
WAPI_TOKEN=
WAPI_WEBHOOK_TOKEN=
