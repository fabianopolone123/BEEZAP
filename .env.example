SECRET_KEY=troque-esta-chave
DEBUG=False
ALLOWED_HOSTS=beezap.seudominio.com,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://beezap.seudominio.com

# URL publica dos arquivos estaticos.
# - Padrao (dominio proprio): /static/
# - Se o app roda sob um prefixo de caminho (ex.: dominio.com/beezap/): /beezap/static/
STATIC_URL=/beezap/static/

# SQLite temporario para homologacao simples:
DATABASE_URL=sqlite:////var/www/beezap/db.sqlite3

# PostgreSQL recomendado para evolucao:
# DATABASE_URL=postgresql://beezap_user:troque-a-senha@127.0.0.1:5432/beezap_db

WAPI_BASE_URL=https://api.w-api.app
WAPI_INSTANCE_ID=
WAPI_TOKEN=
WAPI_WEBHOOK_TOKEN=

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_TIMEOUT=30
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_PREDICT=180
OLLAMA_NUM_GPU=0
